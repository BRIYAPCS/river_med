NODE_ENV=production
PORT=4000

# Frontend URL — used to build password reset links in emails
FRONTEND_URL=https://river-med-app.vercel.app

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=rivermed
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=river_med

JWT_SECRET=CHANGE_THIS_TO_64_RANDOM_CHARS
JWT_EXPIRES_IN=7d

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
# EMAIL_FROM uses onboarding@resend.dev for testing (sends to owner email only).
# For production, add a verified domain and change EMAIL_FROM.
EMAIL_PROVIDER_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=River Med <onboarding@resend.dev>

# ── SMS (Twilio) — optional ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
