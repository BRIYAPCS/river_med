# ── Development (local) ───────────────────────────────────────────────────────
# VITE_API_BASE is intentionally empty — vite.config.js proxy forwards
# /api → http://localhost:4000, so no explicit host is needed.
VITE_API_BASE=

# Socket.IO connects directly to the local backend
VITE_SOCKET_URL=http://localhost:4000
